+absl::Status LlmLiteRtCompiledModelExecutorBase::CacheInputTensorDimensions() {
+  if (model_ == nullptr) {
+    return absl::FailedPreconditionError(
+        "Cannot cache input tensor dimensions without model metadata.");
+  }
+  if (compiled_model_ == nullptr) {
+    return absl::FailedPreconditionError(
+        "Cannot cache input tensor descriptors without compiled model.");
+  }
+  input_tensor_dimensions_.clear();
+  input_tensor_descriptors_.clear();
+  LITERT_ASSIGN_OR_RETURN(auto signatures, model_->GetSignatures());
+  for (const auto& signature : signatures) {
+    const auto signature_key = signature.Key();
+    LITERT_ASSIGN_OR_RETURN(size_t signature_index,
+                            compiled_model_->GetSignatureIndex(signature_key));
+    for (const auto input_name : signature.InputNames()) {
+      LITERT_ASSIGN_OR_RETURN(const SimpleSignature& sig,
+                              model_->FindSignature(signature_key));
+      LITERT_ASSIGN_OR_RETURN(const SimpleTensor& tensor,
+                              sig.InputTensor(input_name));
+      LITERT_ASSIGN_OR_RETURN(const RankedTensorType ranked_tensor_type,
+                              tensor.RankedTensorType());
+      auto dimensions = ranked_tensor_type.Layout().Dimensions();
+      std::vector<int> cached_dimensions(dimensions.begin(), dimensions.end());
+
+      LITERT_ASSIGN_OR_RETURN(auto requirements,
+                              compiled_model_->GetInputBufferRequirements(
+                                  signature_index, input_name));
+      LITERT_ASSIGN_OR_RETURN(auto supported_types,
+                              requirements.SupportedTypes());
+      LITERT_ASSIGN_OR_RETURN(size_t buffer_size, requirements.BufferSize());
+      LITERT_ASSIGN_OR_RETURN(auto strides_span, requirements.Strides());
+      std::vector<uint32_t> strides(strides_span.begin(), strides_span.end());
+      LITERT_ASSIGN_OR_RETURN(size_t alignment, requirements.Alignment());
+
+      const auto key = InputTensorDimensionsKey(signature_key, input_name);
+      input_tensor_dimensions_[key] = cached_dimensions;
+      input_tensor_descriptors_[key] = CachedInputTensorDescriptor{
+          .element_type = ranked_tensor_type.ElementType(),
+          .dimensions = std::move(cached_dimensions),
+          .supported_types = std::move(supported_types),
+          .strides = std::move(strides),
+          .alignment = alignment,
+          .buffer_size = buffer_size,
+      };
+      ABSL_LOG(INFO)
+          << "Cached input tensor descriptor signature=" << signature_key
+          << " input=" << input_name << " dims=["
+          << absl::StrJoin(input_tensor_descriptors_[key].dimensions, ",")
+          << "] supported_types="
+          << input_tensor_descriptors_[key].supported_types.size()
+          << " strides=" << input_tensor_descriptors_[key].strides.size()
+          << " buffer_size=" << buffer_size << " alignment=" << alignment;
+    }
+  }
+  ABSL_LOG(INFO) << "Cached " << input_tensor_descriptors_.size()
+                 << " input tensor descriptors before releasing model.";
+  return absl::OkStatus();
+}
+
+absl::StatusOr<TensorBuffer>
+LlmLiteRtCompiledModelExecutorBase::CreateCachedInputBuffer(
+    absl::string_view signature, absl::string_view tensor_name,
+    absl::Span<const int> dimensions) const {
+  const auto key = InputTensorDimensionsKey(signature, tensor_name);
+  auto cached = input_tensor_descriptors_.find(key);
+  if (cached == input_tensor_descriptors_.end()) {
+    if (model_ != nullptr) {
+      LITERT_ASSIGN_OR_RETURN(auto buffer, compiled_model_->CreateInputBuffer(
+                                               signature, tensor_name));
+      return buffer;
+    }
+    return absl::FailedPreconditionError(
+        absl::StrCat("No cached input tensor descriptor for ", signature, "/",
+                     tensor_name, " after releasing model metadata."));
+  }
+
+  const CachedInputTensorDescriptor& descriptor = cached->second;
+  if (descriptor.supported_types.empty()) {
+    return absl::InternalError(
+        absl::StrCat("No supported tensor buffer types cached for ", signature,
+                     "/", tensor_name));
+  }
+  if (descriptor.alignment == 0) {
+    return absl::InternalError(absl::StrCat(
+        "Invalid cached tensor alignment for ", signature, "/", tensor_name));
+  }
+  for (int dim : dimensions) {
+    if (dim <= 0) {
+      return absl::InvalidArgumentError(
+          absl::StrCat("Cannot create input buffer for ", signature, "/",
+                       tensor_name, " with non-static dimensions [",
+                       absl::StrJoin(dimensions, ","), "]"));
+    }
+  }
+
+  Dimensions resolved_dimensions(dimensions.begin(), dimensions.end());
+  RankedTensorType tensor_type(descriptor.element_type,
+                               Layout(std::move(resolved_dimensions)));
+  LITERT_ASSIGN_OR_RETURN(size_t packed_size, tensor_type.Bytes());
+  size_t buffer_size = packed_size;
+  if (!descriptor.strides.empty()) {
+    buffer_size = std::max(buffer_size, descriptor.buffer_size);
+  }
+  LITERT_ASSIGN_OR_RETURN(auto requirements,
+                          TensorBufferRequirements::CreateWithAlignment(
+                              descriptor.supported_types, buffer_size,
+                              descriptor.alignment, descriptor.strides));
+  LITERT_ASSIGN_OR_RETURN(TensorBuffer buffer,
+                          TensorBuffer::CreateManagedFromRequirements(
+                              env_, tensor_type, requirements));
+  ABSL_LOG(INFO) << "CreateCachedInputBuffer: signature=" << signature
+                 << " input=" << tensor_name << " dims=["
+                 << absl::StrJoin(dimensions, ",")
+                 << "] packed_size=" << packed_size
+                 << " buffer_size=" << buffer_size
+                 << " supported_types=" << descriptor.supported_types.size()
+                 << " strides=" << descriptor.strides.size();
+  return buffer;
+}
+
+absl::Status LlmLiteRtCompiledModelExecutorBase::ResolveCachedDynamicShape(
+    absl::string_view signature, absl::string_view tensor_name, int new_value) {
+  const auto key = InputTensorDimensionsKey(signature, tensor_name);
+  auto cached = input_tensor_dimensions_.find(key);
+  if (cached != input_tensor_dimensions_.end()) {
+    if (!HasDynamicDim(cached->second)) {
+      return absl::OkStatus();
+    }
+    return ResizeDynamicInputTensor(*compiled_model_, signature, tensor_name,
+                                    cached->second, new_value);
+  }
+  if (model_ == nullptr) {
+    return absl::FailedPreconditionError(
+        absl::StrCat("No cached input tensor dimensions for ", signature, "/",
+                     tensor_name, " after releasing model metadata."));
+  }
+  return ResolveDynamicShape(*model_, *compiled_model_, signature, tensor_name,
+                             new_value);
+}
+
+absl::StatusOr<bool> LlmLiteRtCompiledModelExecutorBase::CachedHasDynamicDim(
+    absl::string_view signature, absl::string_view tensor_name) const {
+  const auto key = InputTensorDimensionsKey(signature, tensor_name);
+  auto cached = input_tensor_dimensions_.find(key);
+  if (cached != input_tensor_dimensions_.end()) {
+    return HasDynamicDim(cached->second);
+  }
+  if (model_ == nullptr) {
+    return absl::FailedPreconditionError(
+        absl::StrCat("No cached input tensor dimensions for ", signature, "/",
+                     tensor_name, " after releasing model metadata."));
+  }
+  return HasDynamicDim(*model_, signature, tensor_name);
+}
