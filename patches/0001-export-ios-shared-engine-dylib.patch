+void litert_lm_engine_settings_set_cpu_kernel_mode(
+    LiteRtLmEngineSettings* settings, int cpu_kernel_mode_int) {
+  if (settings && settings->settings) {
+    auto cpu_kernel_mode =
+        static_cast<LiteRtCpuKernelMode>(cpu_kernel_mode_int);
+    switch (cpu_kernel_mode) {
+      case kLiteRtCpuKernelModeXnnpack:
+      case kLiteRtCpuKernelModeReference:
+      case kLiteRtCpuKernelModeBuiltin:
+        break;
+      default:
+        ABSL_LOG(WARNING) << "Ignoring invalid CPU kernel mode: "
+                          << cpu_kernel_mode_int;
+        return;
+    }
+
+    auto& main_settings = settings->settings->GetMutableMainExecutorSettings();
+    auto config = main_settings.MutableBackendConfig<litert::lm::CpuConfig>();
+    if (!config.ok()) {
+      ABSL_LOG(WARNING) << "Failed to get CpuConfig to set CPU kernel mode: "
+                        << config.status();
+      return;
+    }
+    config->kernel_mode = cpu_kernel_mode;
+    main_settings.SetBackendConfig(*config);
+  }
+}
