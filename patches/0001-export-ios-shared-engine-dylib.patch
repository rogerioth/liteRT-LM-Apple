+      &litert_lm_engine_settings_delete);
+  ASSERT_NE(settings, nullptr);
+
+  litert_lm_engine_settings_set_main_activation_data_type(settings.get(), 1);
+  litert_lm_engine_settings_set_vision_activation_data_type(settings.get(), 0);
+  litert_lm_engine_settings_set_audio_activation_data_type(settings.get(), 2);
+
+  EXPECT_EQ(settings->settings->GetMainExecutorSettings()
+                .GetActivationDataType()
+                .value(),
+            litert::lm::ActivationDataType::FLOAT16);
+  ASSERT_TRUE(settings->settings->GetVisionExecutorSettings().has_value());
+  EXPECT_EQ(settings->settings->GetVisionExecutorSettings()
+                ->GetActivationDataType()
+                .value(),
+            litert::lm::ActivationDataType::FLOAT32);
+  ASSERT_TRUE(settings->settings->GetAudioExecutorSettings().has_value());
+  EXPECT_EQ(settings->settings->GetAudioExecutorSettings()
+                ->GetActivationDataType()
+                .value(),
+            litert::lm::ActivationDataType::INT16);
+}
