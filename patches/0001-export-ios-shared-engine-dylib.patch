+absl::StatusOr<std::vector<int>> GetInputTensorDimensions(
+    const Model& model, absl::string_view signature,
+    absl::string_view tensor_name) {
+  LITERT_ASSIGN_OR_RETURN(const SimpleSignature& sig,
+                          model.FindSignature(signature));
+  LITERT_ASSIGN_OR_RETURN(const SimpleTensor& tensor,
+                          sig.InputTensor(tensor_name));
+  LITERT_ASSIGN_OR_RETURN(const RankedTensorType ranked_tensor_type,
+                          tensor.RankedTensorType());
+  auto dimensions = ranked_tensor_type.Layout().Dimensions();
+  return std::vector<int>(dimensions.begin(), dimensions.end());
+}
+
+bool HasDynamicDim(absl::Span<const int> dimensions) {
+  return std::find(dimensions.begin(), dimensions.end(), kDynamicDimValue) !=
+         dimensions.end();
+}
+
+std::vector<int> ResolveDynamicDimensions(absl::Span<const int> dimensions,
+                                          int new_value) {
+  std::vector<int> new_shape;
+  new_shape.reserve(dimensions.size());
+  for (int dim : dimensions) {
+    new_shape.push_back(dim == kDynamicDimValue ? new_value : dim);
+  }
+  return new_shape;
+}
+
+absl::StatusOr<std::vector<std::pair<std::string, int>>>
+GetMemoryOptimizedPrefillWorkGroups(
+    const SortedPrefillSignatureMap& prefill_runner_set, int input_length) {
+  if (prefill_runner_set.empty()) {
+    return absl::InvalidArgumentError("No prefill runner available.");
+  }
+  if (input_length <= 0) {
+    return absl::InvalidArgumentError("Prefill input length must be positive.");
+  }
+
+  std::vector<std::pair<std::string, int>> work_groups;
+  while (input_length > 0) {
+    auto selected = prefill_runner_set.end();
+    for (auto it = prefill_runner_set.begin(); it != prefill_runner_set.end();
+         ++it) {
+      if (it->first <= input_length) {
+        selected = it;
+        break;
+      }
+    }
+    if (selected == prefill_runner_set.end()) {
+      selected = std::prev(prefill_runner_set.end());
+      work_groups.push_back(std::make_pair(selected->second, input_length));
+      input_length = 0;
+    } else {
+      work_groups.push_back(std::make_pair(selected->second, selected->first));
+      input_length -= selected->first;
+    }
+  }
+  return work_groups;
+}
