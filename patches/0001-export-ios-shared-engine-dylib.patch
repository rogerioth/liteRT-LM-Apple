+void litert_lm_engine_settings_set_prefill_batch_sizes(
+    LiteRtLmEngineSettings* settings, const int* prefill_batch_sizes,
+    int count) {
+  if (!settings || !settings->settings || !prefill_batch_sizes || count < 0) {
+    return;
+  }
+
+  auto& main_settings = settings->settings->GetMutableMainExecutorSettings();
+  auto advanced_settings = main_settings.GetAdvancedSettings().value_or(
+      litert::lm::AdvancedSettings());
+  advanced_settings.prefill_batch_sizes.clear();
+  for (int i = 0; i < count; ++i) {
+    if (prefill_batch_sizes[i] <= 0) {
+      ABSL_LOG(WARNING) << "Ignoring invalid prefill batch size: "
+                        << prefill_batch_sizes[i];
+      continue;
+    }
+    advanced_settings.prefill_batch_sizes.insert(prefill_batch_sizes[i]);
+  }
+  main_settings.SetAdvancedSettings(advanced_settings);
+}
+
+void litert_lm_engine_settings_set_advanced_bool(
+    LiteRtLmEngineSettings* settings, int option, bool value) {
+  if (!settings || !settings->settings) {
+    return;
+  }
+
+  auto& main_settings = settings->settings->GetMutableMainExecutorSettings();
+  auto advanced_settings = main_settings.GetAdvancedSettings().value_or(
+      litert::lm::AdvancedSettings());
+
+  switch (static_cast<LiteRtLmAdvancedBoolOption>(option)) {
+    case kLiteRtLmAdvancedClearKvCacheBeforePrefill:
+      advanced_settings.clear_kv_cache_before_prefill = value;
+      break;
+    case kLiteRtLmAdvancedMadviseOriginalSharedTensors:
+      advanced_settings.gpu_madvise_original_shared_tensors = value;
+      break;
+    case kLiteRtLmAdvancedConvertWeightsOnGpu:
+      advanced_settings.convert_weights_on_gpu = value;
+      break;
+    case kLiteRtLmAdvancedWaitForWeightsConversionCompleteInBenchmark:
+      advanced_settings.wait_for_weights_conversion_complete_in_benchmark =
+          value;
+      break;
+    case kLiteRtLmAdvancedOptimizeShaderCompilation:
+      advanced_settings.optimize_shader_compilation = value;
+      break;
+    case kLiteRtLmAdvancedCacheCompiledShadersOnly:
+      advanced_settings.cache_compiled_shaders_only = value;
+      break;
+    case kLiteRtLmAdvancedShareConstantTensors:
+      advanced_settings.share_constant_tensors = value;
+      break;
+    case kLiteRtLmAdvancedSamplerHandlesInput:
+      advanced_settings.sampler_handles_input = value;
+      break;
+    case kLiteRtLmAdvancedAllowSrcQuantizedFcConvOps:
+      advanced_settings.allow_src_quantized_fc_conv_ops = value;
+      break;
+    case kLiteRtLmAdvancedHintWaitingForCompletion:
+      advanced_settings.hint_waiting_for_completion = value;
+      break;
+    case kLiteRtLmAdvancedGpuContextLowPriority:
+      advanced_settings.gpu_context_low_priority = value;
+      break;
+    case kLiteRtLmAdvancedDisableDelegateClustering:
+      advanced_settings.disable_delegate_clustering = value;
+      break;
+    default:
+      ABSL_LOG(WARNING) << "Ignoring invalid advanced bool option: " << option;
+      return;
+  }
+
+  main_settings.SetAdvancedSettings(advanced_settings);
+}
+
+void litert_lm_engine_settings_set_gpu_external_tensor_mode(
+    LiteRtLmEngineSettings* settings, bool external_tensor_mode) {
+  if (!settings || !settings->settings) {
+    return;
+  }
+
+  auto& main_settings = settings->settings->GetMutableMainExecutorSettings();
+  auto config = main_settings.MutableBackendConfig<litert::lm::GpuConfig>();
+  if (!config.ok()) {
+    ABSL_LOG(WARNING)
+        << "Failed to get GpuConfig to set external tensor mode: "
+        << config.status();
+    return;
+  }
+  config->external_tensor_mode = external_tensor_mode;
+  main_settings.SetBackendConfig(*config);
+}
+
+void litert_lm_engine_settings_set_gpu_hint_kernel_batch_size(
+    LiteRtLmEngineSettings* settings, int hint_kernel_batch_size) {
+  if (!settings || !settings->settings) {
+    return;
+  }
+
+  auto& main_settings = settings->settings->GetMutableMainExecutorSettings();
+  auto advanced_settings = main_settings.GetAdvancedSettings().value_or(
+      litert::lm::AdvancedSettings());
+  if (hint_kernel_batch_size > 0) {
+    advanced_settings.hint_kernel_batch_size = hint_kernel_batch_size;
+  } else {
+    advanced_settings.hint_kernel_batch_size.reset();
+  }
+  main_settings.SetAdvancedSettings(advanced_settings);
+}
