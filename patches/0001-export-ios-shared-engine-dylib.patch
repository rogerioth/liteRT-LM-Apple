+std::optional<bool> ReleaseVisionExecutorAfterEncodeOverride() {
+  const char* value =
+      std::getenv("LITERT_LM_RELEASE_VISION_EXECUTOR_AFTER_ENCODE");
+  if (value == nullptr) {
+    return std::nullopt;
+  }
+  const std::string normalized = absl::AsciiStrToLower(value);
+  if (normalized == "1" || normalized == "true" || normalized == "yes" ||
+      normalized == "on") {
+    return true;
+  }
+  if (normalized == "0" || normalized == "false" || normalized == "no" ||
+      normalized == "off") {
+    return false;
+  }
+  ABSL_LOG(WARNING)
+      << "Ignoring invalid LITERT_LM_RELEASE_VISION_EXECUTOR_AFTER_ENCODE="
+      << value;
+  return std::nullopt;
 }

+absl::StatusOr<bool> ShouldReleaseVisionExecutorAfterEncode(
+    LlmExecutor& executor) {
+  if (auto env_override = ReleaseVisionExecutorAfterEncodeOverride()) {
+    return *env_override;
+  }
+#if defined(__APPLE__)
+  ASSIGN_OR_RETURN(auto executor_settings, executor.GetExecutorSettings());
+  return executor_settings.GetBackend() == Backend::GPU;
+#else
+  return false;
+#endif
+}
